# Real mode only (the scripted demo needs none of these).
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o
# The endpoint your themed MCP server is hosted at (groups your hero tools):
THEME_MCP_SERVER_URL=https://your-theme-mcp.example.com
# Set by toolbox_setup output when going real:
# TOOLBOX_MCP_ENDPOINT=.../toolboxes/space-mission-control/mcp?api-version=v1
# TOOLBOX_BEARER=<token for scope https://ai.azure.com/.default>

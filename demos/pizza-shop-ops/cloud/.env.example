# Pizza Shop Ops — CLOUD (hosted agent) config.
# Local mock demo needs NONE of this (see ../README.md -> `make demo`).

# Your deployed chat model deployment name (azd provisions one, e.g. gpt-4o / gpt-4o-mini).
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# The toolbox's versioned MCP endpoint, printed by `azd ai toolbox create pizza-shop-ops`.
# Looks like:
#   https://<account>.services.ai.azure.com/api/projects/<project>/toolboxes/pizza-shop-ops/versions/1/mcp?api-version=v1
TOOLBOX_ENDPOINT=

# Injected by `azd ai agent run` from your azd environment — do NOT hand-set in prod:
#   FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
